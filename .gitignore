# Hydra default multirun/sweep output (ephemeral; do not commit)
outputs/

# Dataset tree lives in-repo; ignore bulk (downloads + processed outputs)
datasets/raw/*
!datasets/raw/.gitkeep
datasets/processed/*
!datasets/processed/.gitkeep
datasets/camponotus_raw/in_situ/*
!datasets/camponotus_raw/in_situ/.gitkeep
datasets/camponotus_raw/external/images/*
!datasets/camponotus_raw/external/images/.gitkeep
datasets/camponotus_processed/*
!datasets/camponotus_processed/.gitkeep
datasets/camponotus_yolo/*
!datasets/camponotus_yolo/.gitkeep
datasets/camponotus_coco/*
!datasets/camponotus_coco/.gitkeep
datasets/ants_yolo/
datasets/ants_coco/*
!datasets/ants_coco/README.md

# Training runs (Ultralytics)
experiments/yolo/
# RF-DETR / DETR runs (same policy as yolo/); keep folder README tracked
experiments/detr/*
!experiments/detr/README.md
# RF-DETR ants EXP-A005 runs
experiments/rfdetr/*
!experiments/rfdetr/README.md

# EXP-000 / smoke metrics (regenerate via scripts/run_smoke_test.sh)
experiments/results/*.json

# EXP-000 figures (regenerate via scripts/run_visualization.sh)
experiments/visualizations/

# Local weights / exports (keep models/.gitkeep + README only)
models/*
!models/.gitkeep
!models/README.md
*.pt
*.pth
*.ckpt

# Python bytecode and caches (local / version-specific; do not commit)
__pycache__/
*.py[cod]
*.pyc
*.pyo
.Python
