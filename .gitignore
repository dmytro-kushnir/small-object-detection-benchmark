# Hydra default multirun/sweep output (ephemeral; do not commit)
outputs/

# Bulk dataset tree: usually a machine-local symlink (e.g. to another mount).
# Canonical prep script lives in scripts/datasets/ (version-controlled).
/datasets

# Training runs (Ultralytics); only .gitkeep dirs are tracked
experiments/yolo/

# Local weights / exports under models/ (keep models/.gitkeep only)
models/*
!models/.gitkeep

# Python bytecode and caches (local / version-specific; do not commit)
__pycache__/
*.py[cod]
*.pyc
*.pyo
.Python
