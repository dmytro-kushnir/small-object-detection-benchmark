# Hydra default multirun/sweep output (ephemeral; do not commit)
outputs/

# Ultralytics / detection runs — exported visualization videos (e.g. runs/detect/.../results/video_try_*/)
runs/**/*.avi
runs/**/*.mp4
runs/**/*.mov
runs/**/*.mkv
runs/**/*.webm
runs/**/*.gif

# Dataset tree lives in-repo; ignore bulk (downloads + processed outputs)
datasets/raw/*
!datasets/raw/.gitkeep
datasets/processed/*
!datasets/processed/.gitkeep
datasets/camponotus_raw/in_situ/*
!datasets/camponotus_raw/in_situ/.gitkeep
datasets/camponotus_raw/external/images/*
!datasets/camponotus_raw/external/images/.gitkeep
# Packaged raw dumps (e.g. in_situ.zip before unzip into in_situ/)
datasets/camponotus_raw/**/*.zip
datasets/camponotus_processed/*
!datasets/camponotus_processed/.gitkeep
datasets/camponotus_yolo/*
!datasets/camponotus_yolo/.gitkeep
datasets/camponotus_coco/*
!datasets/camponotus_coco/.gitkeep
datasets/camponotus_rfdetr_coco/*
!datasets/camponotus_rfdetr_coco/.gitkeep
# Any split-specific RF-DETR exports (e.g. camponotus_rfdetr_coco_sequence_safe)
datasets/camponotus_rfdetr_coco*/
datasets/camponotus_coco_ant_only/*
!datasets/camponotus_coco_ant_only/.gitkeep
datasets/camponotus_yolo_ant_only/*
!datasets/camponotus_yolo_ant_only/.gitkeep
datasets/ants_yolo/
datasets/ants_coco/*
!datasets/ants_coco/README.md

# Training runs (Ultralytics)
experiments/yolo/
# RF-DETR / DETR runs (same policy as yolo/); keep folder README tracked
experiments/detr/*
!experiments/detr/README.md
# RF-DETR ants EXP-A005 runs
experiments/rfdetr/*
!experiments/rfdetr/README.md

# EXP-000 / smoke metrics (regenerate via scripts/run_smoke_test.sh)
experiments/results/*.json

# Idea 2 hybrid: large COCO prelabel sidecars (regenerate via run_camponotus_idea2_hybrid.sh / bootstrap)
experiments/results/**/camponotus_idea2_*_prelabels_coco.json

# EXP-000 figures (regenerate via scripts/run_visualization.sh)
experiments/visualizations/

# Ad-hoc test frames often saved as browser default names at repo root
/download.jpeg
/download.jpg
/download.png
/download.webp

# infer_rfdetr.py --save-vis (default viz_infer_rfdetr next to --out) + common OOD viz dirs
experiments/results/**/viz_infer_rfdetr/
experiments/results/ood_rfdetr_viz/

# Local weights / exports (keep models/.gitkeep + README only)
models/*
!models/.gitkeep
!models/README.md
*.pt
*.pth
*.ckpt

# Python bytecode and caches (local / version-specific; do not commit)
__pycache__/
*.py[cod]
*.pyc
*.pyo
.Python
